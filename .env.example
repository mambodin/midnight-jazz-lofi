# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
# Production:  .env lives at ~/youtube-pipeline/.env on the VPS (BASE_DIR resolved
#              from config/pipeline.json mode=production).
# Local test:  copy this file to <repo>/.env and run with mode=test (or
#              PIPELINE_MODE=test). Mock Suno + mock Anthropic skip those keys,
#              but PIAPI_KEY + KLING_* are required for the real image+video step.

# Anthropic Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Suno API (sunoapi.org)
SUNO_API_KEY=your_sunoapi_org_key_here
SUNO_CALLBACK_URL=https://webhook.site/your-unique-id-here

# Kling AI API (klingai.com/global/dev) — used for image-to-video step
KLING_ACCESS_KEY=your_kling_access_key_id_here
KLING_SECRET_KEY=your_kling_secret_key_here

# PiAPI (piapi.ai) — used for the Flux Schnell text-to-image step
PIAPI_KEY=your_piapi_key_here

# YouTube OAuth (generated by get_token.py)
YOUTUBE_CLIENT_SECRET_PATH=/home/ubuntu/youtube-pipeline/client_secret.json
YOUTUBE_TOKEN_PATH=/home/ubuntu/youtube-pipeline/token.json
